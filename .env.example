# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# For local MongoDB installation
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.mongodb.net/drawing_grid_maker?retryWrites=true&w=majority&appName=Cluster0

# For MongoDB Atlas (cloud database)
# MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/drawing_grid_maker?retryWrites=true&w=majority

# JWT Authentication Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
JWT_EXPIRES_IN=24h

# File Upload Configuration
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png

# CORS Configuration
CLIENT_URL=http://localhost:3000
# Optional: comma-separated list for multiple clients (local + deployed frontend)
# CLIENT_URLS=http://localhost:3000,https://your-frontend-domain.vercel.app

# Security Settings
BCRYPT_SALT_ROUNDS=12

# GridFS Configuration (for large file storage)
GRIDFS_BUCKET=images

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# Email Configuration (for password reset, etc.)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# AWS S3 Configuration (alternative to local file storage)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_BUCKET_NAME=drawing-grid-maker-uploads
# AWS_REGION=us-east-1

# Redis Configuration (for session storage - optional)
# REDIS_URL=redis://localhost:6379

# Production Settings
# SESSION_SECRET=your_session_secret_here
# TRUST_PROXY=true
# SECURE_COOKIES=true

# Analytics (optional)
# GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Error Monitoring (optional)
# SENTRY_DSN=your_sentry_dsn_here